*.crt
nix.conf*
nix.custom.conf*
registry.json
*.log

# Private age identities (/etc/nix/age/<owner>) — secret keys sops decrypts with, NEVER commit. Only
# the public keys (in secrets/.sops.yaml) are tracked.
/age/

# Plaintext VPN profiles — encrypt with sops-stash before staging, never commit raw.
*.ovpn

# Machine-local runtime env overrides, sourced at shell startup. Never commit.
.env
